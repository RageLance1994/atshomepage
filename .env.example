# ── ElevenLabs (obbligatori per la voice demo) ────────────────────────────────
ELEVENLABS_API_KEY=sk-...
ELEVENLABS_AGENT_ID=agent_...

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── CORS: origini ammesse per le API (virgola-separated) ─────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://atsco.it,https://www.atsco.it

# ── Demo token opzionale ──────────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# DEMO_SECRET=

# ── Budget giornaliero sessioni ElevenLabs ────────────────────────────────────
MAX_DAILY_SESSIONS=200

# ── IP da bloccare permanentemente (virgola-separated) ────────────────────────
# BLOCKED_IPS=1.2.3.4,5.6.7.8
