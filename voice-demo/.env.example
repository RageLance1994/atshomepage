# ── ElevenLabs (obbligatori) ──────────────────────────────────────────────────
ELEVENLABS_API_KEY=sk-...
ELEVENLABS_AGENT_ID=agent_...

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── CORS: origini ammesse (virgola-separated) ─────────────────────────────────
# In produzione metti solo il tuo dominio
ALLOWED_ORIGINS=http://localhost:3000,https://atsco.it,https://www.atsco.it

# ── Demo token opzionale ──────────────────────────────────────────────────────
# Se impostato, il frontend deve mandare header X-Demo-Token: <questo valore>
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# DEMO_SECRET=

# ── Budget giornaliero (numero max sessioni ElevenLabs al giorno) ─────────────
MAX_DAILY_SESSIONS=200

# ── IP da bloccare permanentemente (virgola-separated, opzionale) ─────────────
# BLOCKED_IPS=1.2.3.4,5.6.7.8
